# En az 32 rastgele karakter. Pine alarmındaki webhookKey ile aynı olmalı.
FINPILOT_WEBHOOK_SECRET=BURAYA_EN_AZ_32_KARAKTER_RASTGELE_ANAHTAR

FINPILOT_HOST=127.0.0.1
FINPILOT_PORT=4310
FINPILOT_DATA_FILE=./data/events.jsonl

# Yalnız ters vekil arkasında çalıştırıyorsanız true yapın.
FINPILOT_TRUST_PROXY=false

# İsteğe bağlı: virgülle ayrılmış kaynak IP listesi.
# TradingView güncel IP listesini kurulum belgesinden doğrulamadan doldurmayın.
FINPILOT_ALLOWED_IPS=
