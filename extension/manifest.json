{
  "manifest_version": 3,
  "name": "FinPilot Multi-Market Agent",
  "version": "3.0.0",
  "description": "Walk-forward doğrulama, rejim seçimi, KAP olay analizi, kâğıt emir yaşam döngüsü ve portföy riski kullanan BIST + Binance araştırma paneli.",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel", "alarms", "notifications"],
  "host_permissions": ["https://*.tradingview.com/*", "https://www.isyatirim.com.tr/*", "https://www.borsaistanbul.com/*", "https://kap.org.tr/*", "https://www.kap.org.tr/*", "https://api.binance.com/*", "https://api1.binance.com/*", "https://data-api.binance.vision/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "FinPilot Multi-Market panelini aç" },
  "side_panel": { "default_path": "panel.html" },
  "content_scripts": [
    {
      "matches": ["https://*.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
