{
  "name": "finpilot-autotrader-v1",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run bootstrap && concurrently -n API,WEB -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build": "npm run db:generate && npm run typecheck && tsup apps/api/src/index.ts --format esm --platform node --sourcemap --out-dir apps/api/dist && vite build --config apps/web/vite.config.ts",
    "start": "node scripts/start.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma-command.mjs generate",
    "db:migrate": "node scripts/prisma-command.mjs migrate deploy",
    "db:dev": "node scripts/prisma-command.mjs migrate dev",
    "bootstrap": "npm run db:generate && npm run db:migrate",
    "simulate": "node --import tsx scripts/simulate.ts",
    "check:pine": "node scripts/check-pine.mjs",
    "check": "npm run test && npm run check:pine && npm run build"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "express": "5.1.0",
    "express-rate-limit": "8.6.0",
    "helmet": "8.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "ws": "8.21.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/node": "24.7.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "5.0.4",
    "concurrently": "9.2.1",
    "prisma": "6.19.3",
    "tsx": "4.20.6",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "vite": "7.1.9",
    "vitest": "4.0.4"
  }
}
