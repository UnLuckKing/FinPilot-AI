# Uygulama her zaman PAPER ile başlar. LIVE_MODE_ENABLED=true tek başına canlı emri açmaz.
NODE_ENV=development
HOST=127.0.0.1
PORT=4310
DATABASE_URL=file:../data/finpilot.db
TRADING_MODE=PAPER
LIVE_MODE_ENABLED=false
ALLOW_LOCAL_PAPER_NO_AUTH=true

# En az 32 rastgele karakter kullanın. Pine alarm gövdesindeki gatewayToken ile aynı olmalıdır.
TV_WEBHOOK_SECRET=change-me-with-at-least-32-random-characters
SESSION_SECRET=change-me-with-at-least-32-random-characters
ADMIN_PASSWORD=change-me

# Canlı adaptör yalnız resmî şablon sağlandığında etkinleştirilir.
BROKER_ADAPTER=PAPER
OSMANLI_WEBHOOK_URL=
OSMANLI_WEBHOOK_TEMPLATE_PATH=
OSMANLI_API_TOKEN=

# 32 baytlık base64 anahtar; şifreli bağlantı sırları için.
FINPILOT_MASTER_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
